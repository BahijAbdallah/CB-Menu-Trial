# Coming Soon Gate Configuration
# Set to 'true' to show the full menu app on menu.chezbeyrouth.com
# Set to 'false' or leave empty to show Coming Soon page
VITE_PUBLIC_LAUNCH=false

# Secret key for preview bypass on custom domain
# Use a long, random string for security
# Access full app on menu.chezbeyrouth.com with ?preview=YOUR_SECRET_KEY
VITE_PREVIEW_KEY=your-secret-preview-key-change-this

# Session Secret (already configured)
SESSION_SECRET=your-secret-key-change-in-production

# Database Configuration (already configured)
DATABASE_URL=your-database-url-here